{
  "enabled": true,
  "name": "Update Steering Docs",
  "description": "After each agent session, reviews the three steering files and updates any that are out of sync with recent code changes",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Review the three steering files in .kiro/steering/ (product.md, tech.md, structure.md) against the current state of the codebase. Read the actual source files in src/ and compare them to what the steering docs describe — check if new modules, dependencies, features, architectural patterns, or API changes are accurately reflected. Update only the steering files that are out of sync. Keep entries concise — these docs are for LLM context, not human prose. If nothing is out of date, do nothing."
  },
  "workspaceFolderName": "Mentro-Extension",
  "shortName": "update-steering-docs"
}